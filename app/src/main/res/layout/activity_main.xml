<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceContainerLowest"
    tools:context=".ui.activity.MainActivity">

    <!-- TopAppBar -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceContainerLowest"
        android:paddingVertical="24dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CURBSTOMP"
            android:gravity="center"
            android:fontFamily="@font/playfair_display"
            android:textColor="?attr/colorPrimary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:textAllCaps="true" />
    </LinearLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <!-- Main Canvas -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Toggles and Options -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <LinearLayout
                        android:id="@+id/rowAccessibility"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">
                            
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Force Kill on Expiry"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="14sp" />
                                
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Required to automatically close blocked apps when their limit is reached or during Instant Focus. Requires Accessibility permission."
                                android:fontFamily="@font/inter"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAccessibility"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="?attr/colorPrimary"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                        
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:id="@+id/rowDeviceAdmin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">
                            
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Uninstall Invincibility"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="14sp" />
                                
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Prevents bypassing restrictions by blocking unauthorized uninstallation of Curbstomp. Requires Device Admin permission."
                                android:fontFamily="@font/inter"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchDeviceAdmin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="?attr/colorPrimary"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                    
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:id="@+id/llExtraHarden"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Extra Harden (Block Settings)"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Completely blocks the Settings app at all times. Prevents any settings modifications."
                                android:fontFamily="@font/inter"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchExtraHarden"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:thumbTint="?attr/colorPrimary"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rules -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Rules Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Rules"
                            android:fontFamily="@font/playfair_display"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="24sp" />

                        <Button
                            android:id="@+id/btnCreateRule"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="NEW RULE"

                            android:fontFamily="@font/inter"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            style="@style/Widget.Material3.Button.TextButton" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRules"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_rule" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Instant Focus -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceDim"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardCornerRadius="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Instant Focus"
                        android:fontFamily="@font/playfair_display"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="24sp"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Quickly block distracting apps for a set duration."
                        android:fontFamily="@font/inter"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp"
                        android:layout_marginBottom="24dp" />

                    <!-- Active Focus UI (Hidden by default) -->
                    <LinearLayout
                        android:id="@+id/llActiveFocus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvActiveFocusCountdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:fontFamily="@font/playfair_display"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />

                        <TextView
                            android:id="@+id/tvActiveFocusMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALLOWED APPS"
                            android:fontFamily="@font/inter"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="16dp" />

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:layout_marginBottom="24dp">
                            <LinearLayout
                                android:id="@+id/llActiveFocusApps"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical" />
                        </HorizontalScrollView>
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <Button
                                android:id="@+id/btnPauseResumeFocus"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="56dp"
                                android:text="PAUSE"
                                android:fontFamily="@font/inter"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:textColor="?attr/colorPrimary"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                app:cornerRadius="0dp"
                                app:strokeColor="?attr/colorOutlineVariant"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btnStopFocus"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="56dp"
                                android:text="STOP"
                                android:fontFamily="@font/inter"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:textColor="?attr/colorError"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                app:cornerRadius="0dp"
                                app:strokeColor="?attr/colorOutlineVariant"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginTop="16dp">

                            <Button
                                android:id="@+id/btnEditFocusApps"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="56dp"
                                android:text="EDIT APPS"
                                android:fontFamily="@font/inter"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:textColor="?attr/colorPrimary"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                app:cornerRadius="0dp"
                                app:strokeColor="?attr/colorOutlineVariant"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btnAddFocusTime"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="56dp"
                                android:text="ADD TIME"
                                android:fontFamily="@font/inter"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:textColor="?attr/colorPrimary"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                app:cornerRadius="0dp"
                                app:strokeColor="?attr/colorOutlineVariant"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Quick Start Buttons -->
                    <LinearLayout
                        android:id="@+id/llQuickStart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">
                        
                        <Button
                            android:id="@+id/btnInstantFocus30m"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="30 MIN"
                            android:fontFamily="@font/inter"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:padding="12dp"
                            android:textColor="?attr/colorPrimary"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:cornerRadius="0dp"
                            app:strokeColor="?attr/colorOutlineVariant"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnInstantFocus1h"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="1 HR"
                            android:fontFamily="@font/inter"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:padding="12dp"
                            android:textColor="?attr/colorPrimary"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:cornerRadius="0dp"
                            app:strokeColor="?attr/colorOutlineVariant"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnCreateInstantFocus"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="CUSTOM"
                            android:fontFamily="@font/inter"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:padding="12dp"
                            android:textColor="?attr/colorPrimary"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:cornerRadius="0dp"
                            app:strokeColor="?attr/colorOutlineVariant" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Security -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceDim"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardCornerRadius="0dp"
                android:layout_marginBottom="48dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="24dp"
                        android:paddingBottom="16dp"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Security"
                            android:fontFamily="@font/playfair_display"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant" />

                    <Button
                        android:id="@+id/btnSetPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginBottom="24dp"
                        android:text="SET PASSWORD"
                        android:fontFamily="@font/inter"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:paddingVertical="16dp"
                        android:textColor="?attr/colorOnPrimary"
                        android:backgroundTint="?attr/colorPrimary"
                        app:cornerRadius="0dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
