<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Rule row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical">

        <!-- Chevron: right (0°) = collapsed, down (90°) = expanded via code -->
        <ImageView
            android:id="@+id/btnExpandRule"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_chevron_down"
            android:rotation="-90"
            app:tint="?attr/colorOnSurfaceVariant"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvRuleName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:text="RULE NAME"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:textSize="13sp" />

        <!-- Hidden texts to preserve Kotlin bindings without crashing -->
        <TextView
            android:id="@+id/tvRuleTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvRuleApps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnEditRule"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="2dp"
                android:src="@drawable/ic_edit_minimal"
                app:tint="?attr/colorOnSurfaceVariant"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/btnDeleteRule"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="2dp"
                android:src="@drawable/ic_trash_minimal"
                app:tint="?attr/colorOnSurfaceVariant"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchRuleActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="?attr/colorPrimary"
                android:minHeight="0dp"
                android:minWidth="0dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Column headers row — shown when expanded -->
    <LinearLayout
        android:id="@+id/llStatColHeaders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="44dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="APP"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="9sp"
            android:fontFamily="@font/inter"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:alpha="0.6" />

        <TextView
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:text="USED"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="9sp"
            android:fontFamily="@font/inter"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:gravity="end"
            android:alpha="0.6" />

        <TextView
            android:layout_width="68dp"
            android:layout_height="wrap_content"
            android:text="REMAINING"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="9sp"
            android:fontFamily="@font/inter"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:gravity="end"
            android:alpha="0.6" />
    </LinearLayout>

    <!-- App rows inflated here -->
    <LinearLayout
        android:id="@+id/llAppStatsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant" />
</LinearLayout>
